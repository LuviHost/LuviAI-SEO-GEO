# ════════════════════════════════════════════════════════════════
#  LuviAI — Environment Configuration
#  Bu dosyayı `.env` olarak kopyalayıp gerçek değerlerle doldurun
# ════════════════════════════════════════════════════════════════

# ─── DATABASE ───────────────────────────────────────────────
# Yerel: docker-compose ile gelen MySQL
DATABASE_URL="mysql://luviai:luviai_dev@localhost:3306/luviai"
REDIS_URL="redis://localhost:6379"

# Şifrelenmiş alan AES-256 key (FTP/SSH credentials için)
# Üret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── API SERVERS ────────────────────────────────────────────
API_PORT=3001
WEB_PORT=3000
API_BASE_URL=http://localhost:3001
WEB_BASE_URL=http://localhost:3000

# Production'da:
# API_BASE_URL=https://api.ai.luvihost.com
# WEB_BASE_URL=https://ai.luvihost.com

# ─── AUTH (NextAuth) ────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (kullanıcı login + GSC erişimi)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# OAuth callback: https://ai.luvihost.com/api/auth/callback/google

# Email magic link
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=noreply@ai.luvihost.com

# ─── AI PROVIDERS ───────────────────────────────────────────
# Anthropic Claude (yazar/editör/diğer ajanlar)
ANTHROPIC_API_KEY=

# Google Gemini (görsel + opsiyonel metin)
GOOGLE_AI_API_KEY=

# Default modeller (her tenant override edebilir)
WRITER_MODEL=claude-sonnet-4-6
EDITOR_MODEL=claude-sonnet-4-6
ROUTING_MODEL=claude-sonnet-4-6
IMAGE_PROVIDER=gemini-flash

# ─── GOOGLE SEARCH CONSOLE ──────────────────────────────────
# Multi-tenant: her kullanıcı kendi GSC OAuth token'ını verir
# Bu sadece API'a izinli scope tanımı:
GSC_SCOPES=https://www.googleapis.com/auth/webmasters.readonly

# Auriti GEO Optimizer CLI (sunucuda kurulu olmalı)
GEO_CLI_PATH=/usr/local/bin/geo
GEO_OPTIMIZER_ENABLED=true

# ─── META (FACEBOOK + INSTAGRAM) ADS ────────────────────────
# https://developers.facebook.com/apps/
# App Mode: Live'a almak icin Privacy Policy + Terms + Data Deletion URL zorunlu.
# Advanced scope'lar (ads_management, pages_manage_ads, business_management,
# instagram_content_publish) icin App Review + Business Verification zorunlu.
META_APP_ID=
META_APP_SECRET=
# Webhook URL'leri (Meta App Dashboard → Facebook Login → Settings'e ekle):
#   Valid OAuth Redirect URIs:    https://ai.luvihost.com/api/oauth/meta-ads/callback
#   Deauthorize Callback URL:     https://ai.luvihost.com/api/oauth/meta-ads/deauthorize
#   Data Deletion Request URL:    https://ai.luvihost.com/api/oauth/meta-ads/data-deletion

# ─── GOOGLE ADS API ─────────────────────────────────────────
# https://ads.google.com/aw/apicenter
# Test Hesap erisimi default; gercek musteri hesaplari icin "Basic Access" basvur.
GOOGLE_ADS_DEV_TOKEN=
# MCC (manager) hesabin musteri ID'si (tireler olmadan, ornek: 1955591888).
# Tek musteri hesabi varsa bos birak.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ─── PAYTR (TR ÖDEME) ────────────────────────────────────────
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=1                # 1=test, 0=live
PAYTR_NOTIFICATION_URL=https://api.ai.luvihost.com/webhooks/paytr/notification
PAYTR_OK_URL=https://ai.luvihost.com/billing/success
PAYTR_FAIL_URL=https://ai.luvihost.com/billing/failure

# ─── EMAIL ──────────────────────────────────────────────────
RESEND_API_KEY=

# ─── STORAGE ────────────────────────────────────────────────
# Görsel + makale yedekleri
STORAGE_PROVIDER=local           # local | s3 | spaces
STORAGE_LOCAL_PATH=/var/luviai/storage
S3_ENDPOINT=
S3_BUCKET=luviai-prod
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=fra1

# ─── MONITORING ─────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ─── FEATURE FLAGS ──────────────────────────────────────────
FEATURE_PAYMENT_REQUIRED=false   # Faz 1 beta'da false (manuel davet)
FEATURE_AUTO_FIRST_ARTICLE=true  # Onboarding sonu otomatik 1 makale
FEATURE_WHITE_LABEL=false        # Faz 3
FEATURE_PUBLIC_API=false         # Faz 3
FEATURE_MULTI_LANG=true          # TR + EN

# ─── PLANS (TL bazlı) ──────────────────────────────────────
PLAN_STARTER_PRICE=499
PLAN_STARTER_ARTICLES=10
PLAN_STARTER_SITES=1

PLAN_PRO_PRICE=1299
PLAN_PRO_ARTICLES=50
PLAN_PRO_SITES=3

PLAN_AGENCY_PRICE=3299
PLAN_AGENCY_ARTICLES=250
PLAN_AGENCY_SITES=10

PLAN_TRIAL_DAYS=14

# ─── SECURITY ───────────────────────────────────────────────
# Rate limiting (Redis-based)
RATE_LIMIT_WINDOW_MS=60000       # 1 dakika
RATE_LIMIT_MAX=60                # 60 istek/dk

# CORS (web → api)
CORS_ORIGINS=http://localhost:3000,https://ai.luvihost.com

# Cookie domain (production için)
COOKIE_DOMAIN=                   # boş = mevcut host. Production: .luvihost.com

# ─── DEBUG ──────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info                   # debug | info | warn | error
DEBUG=false
