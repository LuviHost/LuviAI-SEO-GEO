// LuviAI — Database schema
// Multi-tenant SEO/GEO content platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
//  USERS & AUTH
// ═══════════════════════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          UserRole  @default(USER)
  locale        String    @default("tr") // tr | en

  // Subscription state (PayTR)
  plan          PlanTier  @default(TRIAL)
  trialEndsAt   DateTime?
  subscriptionId String?  @unique  // PayTR subscription ID
  subscriptionStatus SubscriptionStatus @default(TRIAL)

  // Quota (aylık)
  articlesUsedThisMonth Int @default(0)
  articlesQuotaResetAt  DateTime @default(now())

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  sites         Site[]
  jobs          Job[]
  invoices      Invoice[]

  @@index([email])
  @@index([plan, subscriptionStatus])
  @@map("users")
}

enum UserRole {
  USER
  ADMIN
  AGENCY_OWNER  // Faz 3 — white-label
}

enum PlanTier {
  TRIAL
  STARTER
  PRO
  AGENCY
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

// NextAuth tabloları
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ═══════════════════════════════════════════════════════════════
//  SITES & BRAINS (kullanıcının siteleri)
// ═══════════════════════════════════════════════════════════════

model Site {
  id          String   @id @default(cuid())
  userId      String
  url         String                            // https://luvihost.com.tr
  name        String                            // "LuviHost"
  niche       String?                           // hosting | ecommerce | saas | ...
  language    String   @default("tr")           // tr | en | both
  status      SiteStatus @default(ONBOARDING)

  // GSC OAuth token (per-site, kullanıcı isterse her site için ayrı GSC hesabı)
  gscPropertyUrl     String?  // sc-domain:luvihost.com
  gscRefreshToken    String?  @db.Text // şifrelenmiş
  gscConnectedAt     DateTime?

  // Otomatik üretim
  autoGenerationEnabled Boolean @default(false)
  autoGenerationCron    String? // "0 9 * * 1"  (Pazartesi 09:00)
  autoGenerationCount   Int     @default(5)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  brain            Brain?
  publishTargets   PublishTarget[]
  audits           Audit[]
  topicQueues      TopicQueue[]
  articles         Article[]
  jobs             Job[]

  @@index([userId])
  @@index([status])
  @@map("sites")
}

enum SiteStatus {
  ONBOARDING        // wizard tamamlanmamış
  AUDIT_PENDING     // audit henüz çalışmadı
  AUDIT_COMPLETE    // audit hazır
  ACTIVE            // makale üretiyor
  PAUSED            // kullanıcı durdurmuş
  ERROR             // sürekli hata
}

// Brain = kullanıcı sitesinin AI bağlamı (LuviHost'ta .claude/context/'in dinamik versiyonu)
model Brain {
  id        String   @id @default(cuid())
  siteId    String   @unique

  // JSON yapısı (versiyonlu — kullanıcı düzenleyebilir)
  brandVoice    Json   // { tone, banned_words, examples }
  personas      Json   // [{ name, age, expertise, search_intent, cta }]
  competitors   Json   // [{ name, url, strengths, weaknesses }]
  seoStrategy   Json   // { pillars: [{ url, clusters: [...] }] }
  glossary      Json   // [{ term, translation, note }]

  // Sözlük versiyonları (ilerleme için)
  version       Int    @default(1)
  generatedBy   String @default("auto") // auto | manual | hybrid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("brains")
}

// Yayın hedefi (bir site için birden fazla olabilir — örn. WP + GitHub mirror)
model PublishTarget {
  id          String              @id @default(cuid())
  siteId      String
  type        PublishTargetType
  name        String                              // "Production WordPress"
  isDefault   Boolean             @default(false)
  isActive    Boolean             @default(true)

  // Şifrelenmiş credentials JSON
  credentials Json                                // { host, user, password, apiKey, token, ... }

  // Adapter-specific config
  config      Json?                               // { post_status: "draft"|"publish", category_id, ... }

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  lastUsedAt  DateTime?

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@map("publish_targets")
}

enum PublishTargetType {
  WORDPRESS_REST
  WORDPRESS_XMLRPC
  FTP
  SFTP
  CPANEL_API
  GITHUB
  WEBFLOW
  SANITY
  CONTENTFUL
  GHOST
  STRAPI
  WHMCS_KB
  CUSTOM_PHP
  MARKDOWN_ZIP
}

// ═══════════════════════════════════════════════════════════════
//  AUDIT (site sağlık taraması)
// ═══════════════════════════════════════════════════════════════

model Audit {
  id          String      @id @default(cuid())
  siteId      String

  // Genel skor (0-100)
  overallScore Int
  geoScore     Int?       // Auriti GEO skoru

  // Kontrol noktaları (14 madde)
  // { sitemap_xml: { found, score, fixable }, robots_txt: {...}, ... }
  checks      Json

  // Eksik & hata listesi
  issues      Json        // [{ severity, type, page, description, fix_command }]

  // Auto-fix durumu
  autoFixApplied Boolean @default(false)
  fixesApplied   Json?   // ["sitemap_xml", "robots_txt", ...]

  ranAt       DateTime    @default(now())
  durationMs  Int?

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, ranAt])
  @@map("audits")
}

// ═══════════════════════════════════════════════════════════════
//  TOPIC ENGINE
// ═══════════════════════════════════════════════════════════════

model TopicQueue {
  id          String   @id @default(cuid())
  siteId      String

  // 4 katman ham veri (debug + history için)
  planTopics       Json
  gscOpportunities Json
  geoGaps          Json
  competitorMoves  Json

  // Sıralanmış sonuç (topic-ranker AI çıktısı)
  tier1Topics  Json    // [{ topic, score, persona, pillar, auto_command }]
  tier2Topics  Json
  tier3Topics  Json
  improvements Json    // [{ page, issue, fix_command }]

  totalEvaluated Int

  generatedAt  DateTime @default(now())
  expiresAt    DateTime  // 7 gün sonra fresh tarama gerekli

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, generatedAt])
  @@map("topic_queues")
}

// ═══════════════════════════════════════════════════════════════
//  ARTICLES (üretilen makaleler)
// ═══════════════════════════════════════════════════════════════

model Article {
  id          String         @id @default(cuid())
  siteId      String

  topic       String                                  // Orijinal kullanıcı/AI input
  slug        String                                  // shared-hosting-nedir
  title       String
  metaTitle   String?
  metaDescription String?
  category    String?
  language    String         @default("tr")
  persona     String?                                 // Mert | Buse | Erdem Bey | Cem | custom
  pillar      String?                                 // /paylasimli-hosting

  // İçerik (üretim sürecinde dolar)
  bodyMd      String?        @db.LongText
  bodyHtml    String?        @db.LongText
  frontmatter Json?

  // Pipeline çıktıları (her ajan ayrı kayıt)
  agentOutputs Json?         // { keyword, outline, draft, editor, visuals, publish }

  // Görseller
  heroImageUrl  String?
  inlineImages  Json?         // [{ url, alt, position }]

  // SEO
  schemaMarkup  Json?         // [Article, FAQPage, HowTo, ...]
  faqs          Json?         // [{ q, a }]
  internalLinks Json?         // [{ url, anchor }]
  wordCount     Int?
  readingTime   Int?

  // Pipeline metrikleri
  editorScore   Int?
  editorVerdict EditorVerdict?
  totalCost     Decimal?      @db.Decimal(10, 4) // USD

  // Yayın
  status        ArticleStatus @default(DRAFT)
  publishedAt   DateTime?
  publishedTo   Json?         // [{ targetId, url, externalId }]

  // 30 gün sonra performans
  performanceCheckedAt DateTime?
  performanceMetrics   Json?  // { impressions, clicks, ctr, position }

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, slug])
  @@index([siteId, status])
  @@index([publishedAt])
  @@map("articles")
}

enum ArticleStatus {
  DRAFT
  GENERATING
  EDITING
  REVIZE_NEEDED
  READY_TO_PUBLISH
  PUBLISHED
  FAILED
  ARCHIVED
}

enum EditorVerdict {
  PASS
  REVIZE
  FAIL
}

// ═══════════════════════════════════════════════════════════════
//  JOBS (BullMQ — async work)
// ═══════════════════════════════════════════════════════════════

model Job {
  id          String     @id @default(cuid())
  userId      String
  siteId      String?

  type        JobType
  status      JobStatus  @default(QUEUED)
  priority    Int        @default(0)

  payload     Json
  result      Json?
  error       String?    @db.Text
  attempts    Int        @default(0)

  queuedAt    DateTime   @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  // BullMQ link
  bullJobId   String?    @unique

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  site Site? @relation(fields: [siteId], references: [id], onDelete: SetNull)

  @@index([type, status])
  @@index([userId, queuedAt])
  @@map("jobs")
}

enum JobType {
  SITE_AUDIT
  AUTO_FIX
  BRAIN_GENERATE
  TOPIC_ENGINE
  GENERATE_ARTICLE
  PUBLISH_ARTICLE
  GENERATE_IMAGE
  IMPROVE_PAGE
  WEEKLY_BATCH
  PERFORMANCE_CHECK   // 30 gün sonra GSC
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

// ═══════════════════════════════════════════════════════════════
//  BILLING (PayTR)
// ═══════════════════════════════════════════════════════════════

model Invoice {
  id          String   @id @default(cuid())
  userId      String

  paytrTransactionId String? @unique
  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @default("TRY")
  status      InvoiceStatus @default(PENDING)

  description String?
  invoiceUrl  String?  // E-fatura PDF URL'i

  paidAt      DateTime?
  failedAt    DateTime?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ═══════════════════════════════════════════════════════════════
//  ANALYTICS / TELEMETRY
// ═══════════════════════════════════════════════════════════════

model UsageEvent {
  id          String   @id @default(cuid())
  userId      String?
  siteId      String?
  type        String                              // article_generated, audit_run, ...
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@map("usage_events")
}

// API Token kullanımı (Faz 3 — public API için)
model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  name        String
  hashedKey   String   @unique
  prefix      String                              // luvi_live_abc123...
  scopes      Json                                // ["articles:write", "topics:read"]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  revokedAt   DateTime?

  @@index([userId])
  @@map("api_keys")
}
