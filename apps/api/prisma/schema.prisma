// LuviAI — Database schema
// Multi-tenant SEO/GEO content platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
//  USERS & AUTH
// ═══════════════════════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          UserRole  @default(USER)
  locale        String    @default("tr") // tr | en

  // Subscription state (PayTR)
  plan          PlanTier  @default(TRIAL)
  trialEndsAt   DateTime?
  subscriptionId String?  @unique  // PayTR subscription ID
  subscriptionStatus SubscriptionStatus @default(TRIAL)

  // Affiliate referral
  referredByCode String?

  // Quota (aylık)
  articlesUsedThisMonth Int @default(0)
  articlesQuotaResetAt  DateTime @default(now())

  // AI Citation testi kotasi (Sprint BYOK)
  aiCitationTestsThisMonth Int      @default(0)
  aiCitationQuotaResetAt   DateTime @default(now())

  // Whitelabel / Agency (AGENCY_OWNER icin doldurulur)
  whitelabelEnabled    Boolean @default(false)
  whitelabelBrandName  String?  // ornek "Webmasters Ajansı"
  whitelabelLogoUrl    String?
  whitelabelPrimaryColor String? // #6c5ce7
  whitelabelDomain     String?  // ai.ajansadi.com.tr (CNAME)
  whitelabelEmailFrom  String?  // "noreply@ajansadi.com.tr"
  // Agency owner'in altinda calisan client kullanicilar parentAgencyId ile referans
  parentAgencyId       String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  sites         Site[]
  jobs          Job[]
  invoices      Invoice[]
  parentAgency  User?    @relation("AgencyClients", fields: [parentAgencyId], references: [id], onDelete: SetNull)
  clients       User[]   @relation("AgencyClients")
  apiKeys       ApiKey[]

  @@index([email])
  @@index([plan, subscriptionStatus])
  @@map("users")
}

enum UserRole {
  USER
  ADMIN
  AGENCY_OWNER  // Faz 3 — white-label
}

enum PlanTier {
  TRIAL
  STARTER
  PRO
  AGENCY
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

// Site bazli BYOK — kullanicinin OpenAI/xAI/DeepSeek/Perplexity vs API key'leri (Sprint BYOK)
model SiteAiProviderKey {
  id         String   @id @default(cuid())
  siteId     String
  provider   String   // openai | anthropic | gemini | xai | deepseek | perplexity
  enc        String   @db.Text  // AES-256 encrypted (@luviai/shared.encrypt)
  prefix     String   // ilk 8 char gosterim icin
  verified   Boolean  @default(false)
  verifiedAt DateTime?
  lastError  String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, provider])
  @@index([siteId])
  @@map("site_ai_provider_keys")
}

// Public API key (Sprint C — public REST API icin)
model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String                          // "Production server" gibi etiket
  keyHash     String    @unique               // sha256 of token
  prefix      String                          // ilk 8 char gosterim icin
  scopes      Json                            // ["articles:read", "articles:write", "ads:read", ...]
  rateLimit   Int       @default(60)          // istek/dk
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

// NextAuth tabloları
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ═══════════════════════════════════════════════════════════════
//  SITES & BRAINS (kullanıcının siteleri)
// ═══════════════════════════════════════════════════════════════

model Site {
  id          String   @id @default(cuid())
  userId      String
  url         String                            // https://luvihost.com.tr
  name        String                            // "LuviHost"
  niche       String?                           // hosting | ecommerce | saas | ...
  language    String   @default("tr")           // tr | en | both
  status      SiteStatus @default(ONBOARDING)

  // GSC OAuth token (per-site, kullanıcı isterse her site için ayrı GSC hesabı)
  gscPropertyUrl     String?  // sc-domain:luvihost.com
  gscRefreshToken    String?  @db.Text // şifrelenmiş
  gscConnectedAt     DateTime?

  // GA4 OAuth token (opsiyonel — bounce/conversion sinyali için)
  gaPropertyId       String?  // 123456789 (numeric property id)
  gaRefreshToken     String?  @db.Text // şifrelenmiş
  gaConnectedAt      DateTime?

  // Otomatik üretim
  autoGenerationEnabled Boolean @default(false)
  autoGenerationCron    String? // "0 9 * * 1"  (Pazartesi 09:00)
  autoGenerationCount   Int     @default(5)

  // Otopilot — varsayilan AÇIK, tum akisi otomatik yapar
  autopilot         Boolean @default(true)
  // Platform tahmini (auto-detect): wordpress | webflow | wix | ghost | shopify | cpanel-static | unknown
  platform          String?
  platformConfidence Float?  // 0..1
  platformDetectedAt DateTime?

  // GEO ek alanlar
  llmsFullTxt       String?  @db.LongText // tum sitenin AI icin markdown ozeti
  llmsFullTxtAt     DateTime?
  // sameAs sosyal/web profilleri — Organization schema'da kullanilir
  socialProfiles    Json?    // ["https://twitter.com/...", "https://linkedin.com/..."]

  // Webhook bildirimleri (Slack/Discord)
  notifyWebhookUrl  String?  // Slack/Discord incoming webhook URL
  notifyWebhookKind String?  // slack | discord

  // Ads Manager (Faz 11.2 — direkt resmi API'ler, Ryze AI kaldırıldı)
  // Google Ads OAuth
  googleAdsCustomerId    String?  // 123-456-7890
  googleAdsRefreshToken  String?  @db.Text  // sifrelenmis
  googleAdsConnectedAt   DateTime?
  // Meta Ads OAuth
  metaAdsAccountId       String?  // act_1234567890
  metaAdsAccessToken     String?  @db.Text  // sifrelenmis (long-lived)
  metaAdsConnectedAt     DateTime?
  metaPageId             String?  // FB Page ID — campaign creation + auto-boost icin
  metaInstagramActorId   String?  // IG Business Account ID — opsiyonel, IG placement icin
  // Otopilot
  adsAutopilot           Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  brain            Brain?
  publishTargets   PublishTarget[]
  audits           Audit[]
  topicQueues      TopicQueue[]
  articles         Article[]
  jobs             Job[]
  analyticsSnapshots AnalyticsSnapshot[]
  socialChannels   SocialChannel[]
  adCampaigns      AdCampaign[]
  aiProviderKeys   SiteAiProviderKey[]

  @@unique([userId, url])
  @@index([userId])
  @@index([status])
  @@map("sites")
}

enum SiteStatus {
  ONBOARDING        // wizard tamamlanmamış
  AUDIT_PENDING     // audit henüz çalışmadı
  AUDIT_COMPLETE    // audit hazır
  ACTIVE            // makale üretiyor
  PAUSED            // kullanıcı durdurmuş
  ERROR             // sürekli hata
}

// Brain = kullanıcı sitesinin AI bağlamı (LuviHost'ta .claude/context/'in dinamik versiyonu)
model Brain {
  id        String   @id @default(cuid())
  siteId    String   @unique

  // JSON yapısı (versiyonlu — kullanıcı düzenleyebilir)
  brandVoice    Json   // { tone, banned_words, examples }
  personas      Json   // [{ name, age, expertise, search_intent, cta }]
  competitors   Json   // [{ name, url, strengths, weaknesses }]
  seoStrategy   Json   // { pillars: [{ url, clusters: [...] }] }
  glossary      Json   // [{ term, translation, note }]

  // Sözlük versiyonları (ilerleme için)
  version       Int    @default(1)
  generatedBy   String @default("auto") // auto | manual | hybrid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("brains")
}

// Yayın hedefi (bir site için birden fazla olabilir — örn. WP + GitHub mirror)
model PublishTarget {
  id          String              @id @default(cuid())
  siteId      String
  type        PublishTargetType
  name        String                              // "Production WordPress"
  isDefault   Boolean             @default(false)
  isActive    Boolean             @default(true)

  // Şifrelenmiş credentials JSON
  credentials Json                                // { host, user, password, apiKey, token, ... }

  // Adapter-specific config
  config      Json?                               // { post_status: "draft"|"publish", category_id, ... }

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  lastUsedAt  DateTime?

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@map("publish_targets")
}

enum PublishTargetType {
  WORDPRESS_REST
  WORDPRESS_XMLRPC
  FTP
  SFTP
  CPANEL_API
  GITHUB
  WEBFLOW
  SANITY
  CONTENTFUL
  GHOST
  STRAPI
  WHMCS_KB
  CUSTOM_PHP
  MARKDOWN_ZIP
}

// ═══════════════════════════════════════════════════════════════
//  AUDIT (site sağlık taraması)
// ═══════════════════════════════════════════════════════════════

model Audit {
  id          String      @id @default(cuid())
  siteId      String

  // Genel skor (0-100)
  overallScore Int
  geoScore     Int?       // Auriti GEO skoru

  // Kontrol noktaları (14 madde)
  // { sitemap_xml: { found, score, fixable }, robots_txt: {...}, ... }
  checks      Json

  // Eksik & hata listesi
  issues      Json        // [{ severity, type, page, description, fix_command }]

  // Auto-fix durumu
  autoFixApplied Boolean @default(false)
  fixesApplied   Json?   // ["sitemap_xml", "robots_txt", ...]

  ranAt       DateTime    @default(now())
  durationMs  Int?

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, ranAt])
  @@map("audits")
}

// ═══════════════════════════════════════════════════════════════
//  TOPIC ENGINE
// ═══════════════════════════════════════════════════════════════

model TopicQueue {
  id          String   @id @default(cuid())
  siteId      String

  // 4 katman ham veri (debug + history için)
  planTopics       Json
  gscOpportunities Json
  geoGaps          Json
  competitorMoves  Json

  // Sıralanmış sonuç (topic-ranker AI çıktısı)
  tier1Topics  Json    // [{ topic, score, persona, pillar, auto_command }]
  tier2Topics  Json
  tier3Topics  Json
  improvements Json    // [{ page, issue, fix_command }]

  totalEvaluated Int

  generatedAt  DateTime @default(now())
  expiresAt    DateTime  // 7 gün sonra fresh tarama gerekli

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, generatedAt])
  @@map("topic_queues")
}

// ═══════════════════════════════════════════════════════════════
//  ARTICLES (üretilen makaleler)
// ═══════════════════════════════════════════════════════════════

model Article {
  id          String         @id @default(cuid())
  siteId      String

  topic       String                                  // Orijinal kullanıcı/AI input
  slug        String                                  // shared-hosting-nedir
  title       String
  metaTitle   String?
  metaDescription String?
  category    String?
  language    String         @default("tr")
  persona     String?                                 // Mert | Buse | Erdem Bey | Cem | custom
  pillar      String?                                 // /paylasimli-hosting

  // İçerik (üretim sürecinde dolar)
  bodyMd      String?        @db.LongText
  bodyHtml    String?        @db.LongText
  frontmatter Json?

  // Pipeline çıktıları (her ajan ayrı kayıt)
  agentOutputs Json?         // { keyword, outline, draft, editor, visuals, publish }

  // Görseller
  heroImageUrl  String?
  inlineImages  Json?         // [{ url, alt, position }]

  // SEO
  schemaMarkup  Json?         // [Article, FAQPage, HowTo, ...]
  faqs          Json?         // [{ q, a }]
  internalLinks Json?         // [{ url, anchor }]
  wordCount     Int?
  readingTime   Int?

  // Pipeline metrikleri
  editorScore   Int?
  editorVerdict EditorVerdict?
  totalCost     Decimal?      @db.Decimal(10, 4) // USD

  // Yayın
  status        ArticleStatus @default(DRAFT)
  scheduledAt   DateTime?                              // Planlanan üretim/yayın zamanı
  publishedAt   DateTime?
  publishedTo   Json?         // [{ targetId, url, externalId }]

  // 30 gün sonra performans
  performanceCheckedAt DateTime?
  performanceMetrics   Json?  // { impressions, clicks, ctr, position }

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  socialPosts SocialPost[]

  @@unique([siteId, slug])
  @@index([siteId, status])
  @@index([siteId, scheduledAt])
  @@index([publishedAt])
  @@map("articles")
}

enum ArticleStatus {
  DRAFT
  SCHEDULED
  GENERATING
  EDITING
  REVIZE_NEEDED
  READY_TO_PUBLISH
  PUBLISHED
  FAILED
  ARCHIVED
}

enum EditorVerdict {
  PASS
  REVIZE
  FAIL
}

// ═══════════════════════════════════════════════════════════════
//  ANALYTICS — GSC günlük snapshot'ları
// ═══════════════════════════════════════════════════════════════

model AnalyticsSnapshot {
  id          String   @id @default(cuid())
  siteId      String

  // Hangi gün (UTC)
  date        DateTime @db.Date

  // Site-level toplam
  totalClicks      Int
  totalImpressions Int
  avgCtr           Float
  avgPosition      Float

  // Per-page detail JSON: [{ page, query, clicks, impressions, ctr, position }]
  // Top 50 sayfa, top 10 query
  pageDetails  Json
  queryDetails Json

  // Trending: yükselen sorgular (son 7g vs önceki 7g)
  trendingQueries Json?

  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, date])
  @@index([siteId, date])
  @@map("analytics_snapshots")
}

// ═══════════════════════════════════════════════════════════════
//  AI CITATION SNAPSHOTS — gunluk LLM gorunurluk takibi
// ═══════════════════════════════════════════════════════════════

model AiCitationSnapshot {
  id          String   @id @default(cuid())
  siteId      String

  date        DateTime @db.Date  // Hangi gun (UTC)
  provider    String              // anthropic | gemini | openai | perplexity | grok | deepseek
  available   Boolean
  score       Int?                // 0..100, null = kullanilamaz / sorgu yok

  // Probe detaylari (en fazla 5 sorgu)
  probes      Json                // [{ query, cited, brandMentioned, excerpt }]
  citedCount  Int      @default(0)
  mentionedCount Int   @default(0)

  createdAt   DateTime @default(now())

  @@unique([siteId, date, provider])
  @@index([siteId, date])
  @@index([siteId, provider, date])
  @@map("ai_citation_snapshots")
}

// ═══════════════════════════════════════════════════════════════
//  AI CRAWLER HITS — Sunucu loglarindan bot trafigi
// ═══════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════
//  AI REFERRER HITS — ChatGPT/Perplexity'den gelen kullanici trafigi
// ═══════════════════════════════════════════════════════════════

model AiReferrerHit {
  id          String   @id @default(cuid())
  siteId      String

  date        DateTime @db.Date
  referrer    String   // chatgpt | perplexity | claude | gemini | bing-copilot | unknown
  hits        Int      @default(0)
  uniqueUrls  Int      @default(0)
  topUrls     Json     // [{ url, count }]

  createdAt   DateTime @default(now())

  @@unique([siteId, date, referrer])
  @@index([siteId, date])
  @@map("ai_referrer_hits")
}

// ═══════════════════════════════════════════════════════════════
//  ADS MANAGER (Faz 11) — Google Ads + Meta Ads campaign tracking
// ═══════════════════════════════════════════════════════════════

model AdCampaign {
  id            String   @id @default(cuid())
  siteId        String

  platform      String   // google_ads | meta_ads
  externalId    String?  // platform-side campaign ID (Google: 123, Meta: act_123)
  name          String
  objective     String   // traffic | leads | conversions | brand_awareness | sales
  status        String   @default("DRAFT") // DRAFT | PAUSED | ACTIVE | ENDED | FAILED

  // Targeting
  audience      Json?    // { interests, demographics, lookalikes, keywords (Google) }
  locations     Json?    // ["TR", "İstanbul", ...]
  languages     Json?    // ["tr", "en"]

  // Creatives
  headlines     Json?    // [{ text, length }] — Google RSA
  descriptions  Json?    // [{ text }]
  primaryTexts  Json?    // Meta primary text variants
  ctaButton     String?  // SHOP_NOW | LEARN_MORE | SIGN_UP

  // Images / Videos
  creativeAssets Json?   // [{ url, format: square|portrait|landscape, type: image|video }]

  // Budget
  budgetType    String?  // daily | lifetime
  budgetAmount  Decimal? @db.Decimal(10, 2) // TL
  budgetCurrency String  @default("TRY")
  startDate     DateTime?
  endDate       DateTime?

  // Performance (cron her 6 saat update)
  impressions   Int      @default(0)
  clicks        Int      @default(0)
  spend         Decimal  @default(0) @db.Decimal(10, 2)
  conversions   Int      @default(0)
  ctr           Float    @default(0)
  cpc           Float    @default(0)
  roas          Float    @default(0)
  performanceCheckedAt DateTime?
  performanceMetrics Json?

  // Otopilot kararlari
  autopilotActions Json? // [{ time, action, reason }]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, platform])
  @@index([siteId, status])
  @@map("ad_campaigns")
}

model AiCrawlerHit {
  id          String   @id @default(cuid())
  siteId      String

  date        DateTime @db.Date
  bot         String   // GPTBot | ClaudeBot | PerplexityBot | Google-Extended | ...
  hits        Int      @default(0)         // gunluk istek sayisi
  uniqueUrls  Int      @default(0)         // farkli URL sayisi
  topUrls     Json     // [{ url, count }] top 10
  status2xx   Int      @default(0)         // basarili istek
  status4xx   Int      @default(0)         // hatali istek
  status5xx   Int      @default(0)
  bytesServed Int      @default(0)

  createdAt   DateTime @default(now())

  @@unique([siteId, date, bot])
  @@index([siteId, date])
  @@index([siteId, bot, date])
  @@map("ai_crawler_hits")
}

// ═══════════════════════════════════════════════════════════════
//  JOBS (BullMQ — async work)
// ═══════════════════════════════════════════════════════════════

model Job {
  id          String     @id @default(cuid())
  userId      String
  siteId      String?

  type        JobType
  status      JobStatus  @default(QUEUED)
  priority    Int        @default(0)

  payload     Json
  result      Json?
  error       String?    @db.Text
  attempts    Int        @default(0)

  queuedAt    DateTime   @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  // BullMQ link
  bullJobId   String?    @unique

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  site Site? @relation(fields: [siteId], references: [id], onDelete: SetNull)

  @@index([type, status])
  @@index([userId, queuedAt])
  @@map("jobs")
}

enum JobType {
  SITE_AUDIT
  AUTO_FIX
  BRAIN_GENERATE
  TOPIC_ENGINE
  GENERATE_ARTICLE
  PUBLISH_ARTICLE
  GENERATE_IMAGE
  IMPROVE_PAGE
  WEEKLY_BATCH
  PERFORMANCE_CHECK   // 30 gün sonra GSC
  ONBOARDING_CHAIN    // brain → audit → topics → ilk makale
  SOCIAL_PUBLISH      // tek bir SocialPost yayini (cron tetikler)
  PROCESS_SCHEDULED   // scheduledAt <= now olan SCHEDULED makaleleri uretime alir (cron)
  LLMS_FULL_BUILD     // tum site icerigini llms-full.txt'e konsolide et (haftalik)
  AI_CITATION_DAILY   // gunluk Claude/Gemini/OpenAI/Perplexity gorunurluk testi
  CONTENT_PIVOT_CHECK // 30 gun sonra dusuk performans tespit + revize tetikle (haftalik)
  AI_MENTION_ALARM    // gunluk: AI citation drop tespit + email
  ADS_AUTOPILOT       // 6 saatte bir: aktif kampanyalari ROAS'a gore optimize
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

// ═══════════════════════════════════════════════════════════════
//  BILLING (PayTR)
// ═══════════════════════════════════════════════════════════════

model Invoice {
  id          String   @id @default(cuid())
  userId      String

  paytrTransactionId String? @unique
  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @default("TRY")
  status      InvoiceStatus @default(PENDING)

  description String?
  invoiceUrl  String?  // E-fatura PDF URL'i

  paidAt      DateTime?
  failedAt    DateTime?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ═══════════════════════════════════════════════════════════════
//  ANALYTICS / TELEMETRY
// ═══════════════════════════════════════════════════════════════

model UsageEvent {
  id          String   @id @default(cuid())
  userId      String?
  siteId      String?
  type        String                              // article_generated, audit_run, ...
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@map("usage_events")
}

// ═══════════════════════════════════════════════════════════════
//  AFFILIATE PROGRAMı (Faz 2 Hafta 11)
// ═══════════════════════════════════════════════════════════════

model Affiliate {
  id              String   @id @default(cuid())
  userId          String   @unique
  refCode         String   @unique          // luvi-emir-2026
  commissionPct   Float    @default(30)     // %30 komisyon
  active          Boolean  @default(true)

  totalReferred   Int      @default(0)
  totalRevenue    Decimal  @default(0) @db.Decimal(10, 2)
  totalCommission Decimal  @default(0) @db.Decimal(10, 2)
  totalPaid       Decimal  @default(0) @db.Decimal(10, 2)

  payoutMethod    String?                   // "iban" | "papara"
  payoutDetails   Json?                     // şifrelenmiş

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  referrals       AffiliateReferral[]

  @@map("affiliates")
}

model AffiliateReferral {
  id              String   @id @default(cuid())
  affiliateId     String
  referredUserId  String

  clickedAt       DateTime @default(now())
  signedUpAt      DateTime?
  firstPaidAt     DateTime?

  commissionUntil DateTime?                 // 3 ay sonra biter
  totalCommissionEarned Decimal @default(0) @db.Decimal(10, 2)

  status          String   @default("clicked")  // clicked | signed_up | paid | expired

  affiliate       Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([referredUserId])
  @@index([affiliateId, status])
  @@map("affiliate_referrals")
}

// ═══════════════════════════════════════════════════════════════
//  EMAIL OUTBOUND TRACKING
// ═══════════════════════════════════════════════════════════════

model EmailLog {
  id          String   @id @default(cuid())
  userId      String?
  to          String
  template    String                        // welcome_day0 | trial_expiry | weekly_report
  subject     String
  status      String   @default("sent")     // sent | delivered | opened | bounced

  resendId    String?  @unique
  metadata    Json?

  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([template, createdAt])
  @@map("email_logs")
}

// (Eski Faz 3 ApiKey placeholder modeli kaldirildi — Sprint C'de yukaridaki ApiKey modeli kullaniliyor)

// ─────────────────────────────────────────────────────────────────
// Sosyal Medya — kanal + post + recurring slot
// PublishTarget'a paralel ama sosyal kanal bazli (LI/X/FB/IG/TT/YT/Threads/BS/Pin/GMB)
// ─────────────────────────────────────────────────────────────────

model SocialChannel {
  id          String   @id @default(cuid())
  siteId      String
  type        SocialChannelType
  name        String                              // "LuviHost LinkedIn" gibi kullanici etiketi
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)            // makale yayini sonrasi otomatik dagit (opt-in)

  // OAuth + credentials (sifrelenmis JSON)
  credentials String   @db.Text                   // encrypt(JSON.stringify({ accessToken, refreshToken, expiresAt, ... }))
  config      Json?                               // kanal-bazli ek ayar: pageId, ugcUrn, accountId

  // Account metadata (UI'da gostermek icin)
  externalId      String?                         // LI URN, FB Page ID, IG Business Account ID
  externalName    String?                         // "Emirhan Burgazli" / "LuviHost Co."
  externalAvatar  String?  @db.VarChar(1000)      // LinkedIn CDN URL'leri 500+ karakter olabiliyor

  lastUsedAt  DateTime?
  lastError   String?  @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site            Site                  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  posts           SocialPost[]
  recurringSlots  SocialRecurringSlot[]

  @@unique([siteId, type, externalId])           // ayni site icin ayni kanal+hesap iki kez eklenmesin
  @@index([siteId])
  @@index([type])
  @@map("social_channels")
}

enum SocialChannelType {
  LINKEDIN_PERSONAL
  LINKEDIN_COMPANY
  X_TWITTER
  FACEBOOK_PAGE
  INSTAGRAM_BUSINESS
  TIKTOK
  YOUTUBE
  THREADS
  BLUESKY
  PINTEREST
  GMB                 // Google Business Profile
  MASTODON
}

model SocialPost {
  id          String   @id @default(cuid())
  channelId   String
  articleId   String?                              // makaleden tureyense bagli, bagimsizsa null

  // Icerik (kanal-formati uygulanmis)
  text        String   @db.Text                    // ana metin
  mediaUrls   Json?                                // [{url, type:'image'|'video', altText}]
  metadata    Json?                                // hashtags, mentions, link, threadParts

  // Scheduling
  status      SocialPostStatus @default(DRAFT)
  scheduledFor DateTime?                           // null = "hemen" veya manuel
  publishedAt DateTime?

  // Yayin sonucu
  externalId  String?                              // LI urn, X tweet id, FB post id
  externalUrl String?                              // public URL (https://linkedin.com/feed/update/urn:li:...)
  errorMsg    String?  @db.Text
  retryCount  Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  channel  SocialChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  article  Article?      @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@index([channelId, status])
  @@index([scheduledFor])
  @@index([articleId])
  @@map("social_posts")
}

enum SocialPostStatus {
  DRAFT                // taslak — kullanici onaylamadi
  QUEUED               // zamanlanmis, scheduledFor bekleniyor
  PUBLISHING           // yayina gonderiliyor
  PUBLISHED            // basariyla yayinlandi
  FAILED               // yayin basarisiz, retry edilebilir
  CANCELED             // kullanici iptal etti
}

// Haftalik recurring slot — "her Pazartesi 09:00 LI'ye queue'dan 1 post"
model SocialRecurringSlot {
  id          String   @id @default(cuid())
  channelId   String

  dayOfWeek   Int                                  // 0 (Pazar) - 6 (Cumartesi)
  hour        Int                                  // 0-23
  minute      Int                                  // 0-59
  timezone    String   @default("Europe/Istanbul")

  // Slot ne yapsin?
  source      SocialSlotSource @default(QUEUE)    // QUEUE: kullanici taslagindan ilk siradakini cek; AUTO: 09-social-writer ile yeni uret
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  channel  SocialChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@map("social_recurring_slots")
}

enum SocialSlotSource {
  QUEUE                // kullanici draft'larindan al
  AUTO                 // 09-social-writer ile yeni uret
}

// Faz 11.4 — Generic key-value store (AI cost counter, daily quota, vb.)
model KvStore {
  key       String   @id
  value     String   @db.Text
  expiresAt DateTime?
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
  @@map("kv_store")
}
