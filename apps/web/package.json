{
  "name": "@luviai/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "postbuild": "node -e \"const fs=require('fs'),p=require('path');const sd=p.join('.next','standalone','apps','web');if(!fs.existsSync(sd))process.exit(0);fs.cpSync(p.join('.next','static'),p.join(sd,'.next','static'),{recursive:true,force:true});if(fs.existsSync('public'))fs.cpSync('public',p.join(sd,'public'),{recursive:true,force:true});console.log('postbuild: standalone static + public synced');\"",
    "start": "next start -p 3000",
    "lint": "next lint"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.0",
    "@prisma/client": "^6.0.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.0",
    "@sentry/nextjs": "^10.51.0",
    "animejs": "^4.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "lucide-react": "^0.469.0",
    "marked": "^14.1.4",
    "next": "^15.1.0",
    "next-auth": "^5.0.0-beta.25",
    "next-intl": "^3.26.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@luviai/shared": "workspace:*",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
